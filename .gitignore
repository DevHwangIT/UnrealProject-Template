# =========================
# Unreal Engine 5 .gitignore
# =========================

# Visual Studio / Rider / VSCode
.vs/
.vscode/
.idea/
*.VC.db
*.VC.opendb
*.sln
*.suo
*.opensdf
*.sdf
*.user
*.userprefs
*.csproj
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

# OS files
.DS_Store
Thumbs.db

# Unreal Engine generated folders
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/*/FileOpenOrder/
Build/*/Metadata/

# Local build files
*.uatbuildrecord
*.tmp
*.log

# Packaging
*.apk
*.ipa

# Unreal generated project files
*.sln
*.xcodeproj
*.xcworkspace

# JetBrains Rider
.idea/

# Visual Studio Code
.vscode/

# Unreal Engine cache
DerivedDataCache/*

# Ignore crash reports
Saved/Crashes/
Saved/Logs/
Saved/Temp/

# Ignore local config
Saved/Config/WindowsEditor/

# Optional: ignore autosaves
Saved/Autosaves/

# Ignore cooked data
Saved/Cooked/

# Ignore shader cache
Saved/Shaders/

# Ignore staging
Saved/StagedBuilds/

# Unreal Engine plugin binaries
Plugins/*/Binaries/
Plugins/*/Intermediate/

# Keep plugin source
!Plugins/*/Source/**

# Ignore compiled assets
*.pdb
*.obj
*.o
*.so
*.dll
*.exe
*.app

# Rider / Resharper
_ReSharper*/
*.DotSettings.user

# Node (for web plugins/tools)
node_modules/

# Python cache
__pycache__/
*.pyc

# Allow config files
!Config/*.ini

# Allow source and content
!Source/**
!Content/**

# Allow plugin content
!Plugins/*/Content/**